{
  "expo": {
    "name": "Hypertrophy Helper",
    "slug": "cjladd-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cjladdapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cjladd.hypertrophyhelper",
      "teamId": "5XKGN89TY8",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Hypertrophy Helper reads your HRV, resting heart rate, and sleep data to compute muscle recovery scores.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Hypertrophy Helper reads your HRV, resting heart rate, and sleep data to compute muscle recovery scores.",
          "background": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-asset",
      "onnxruntime-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "700a6432-20a8-47fe-9e10-554d0d8ff046"
      }
    },
    "owner": "cjladd",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/700a6432-20a8-47fe-9e10-554d0d8ff046"
    }
  }
}
